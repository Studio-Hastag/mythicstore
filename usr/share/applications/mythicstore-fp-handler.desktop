Icon=mythicstore
Terminal=false
Type=Application
Encoding=UTF-8
NoDisplay=true
MimeType=application/vnd.flatpak.ref;application/vnd.flatpak.repo;x-scheme-handler/flatpak+https;x-scheme-handler/flatpak+http;
Name[C]=mythicstore-fp-handler.desktop
