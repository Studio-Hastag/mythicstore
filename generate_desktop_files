#!/usr/bin/python3

DOMAIN = "mythicstore"
PATH = "/usr/share/mythicos/locale"
KEYWORDS = "program,software,store,repository,package,add,install,uninstall,remove,apps,applications,games,flatpak"

import os
import gettext
import mythiccommon.additionalfiles as additionalfiles

os.environ['LANGUAGE'] = "en_US.UTF-8"
gettext.install(DOMAIN, PATH)

prefix = "[Desktop Entry]\n"

suffix = """Exec=mythicstore
Icon=mythicstore
Terminal=false
Type=Application
Encoding=UTF-8
Categories=Application;System;Settings;XFCE;X-XFCE-SettingsDialog;X-XFCE-SystemSettings;
NotShowIn=KDE;
StartupNotify=true
"""

additionalfiles.generate(DOMAIN, PATH, "usr/share/applications/mythicstore.desktop", prefix, _("Software Manager"), _("Install new applications"), suffix, keywords=KEYWORDS)

suffix = """Exec=mythicstore
Icon=software-properties-mint
Terminal=false
Type=Application
Encoding=UTF-8
Categories=System;
OnlyShowIn=KDE;
"""

additionalfiles.generate(DOMAIN, PATH, "usr/share/applications/mythicstore-kde.desktop", prefix, _("Software Manager"), _("Install new applications"), suffix, genericName=_("Install new applications"), keywords=KEYWORDS)
